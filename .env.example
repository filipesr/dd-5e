# D&D 5e Toolkit — Environment Variables
# Copy this file to .env.local and fill in values

# ── Supabase (Phase 2 — not required for MVP) ──
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Open5e API (optional — defaults to public API) ──
# NEXT_PUBLIC_OPEN5E_BASE_URL=https://api.open5e.com/v1

# ── Anthropic API (Phase 2 — NPC generator with AI) ──
# ANTHROPIC_API_KEY=sk-ant-...
